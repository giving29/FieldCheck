<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>LOVB · The Pro Pathway — FieldCheck</title>
<meta name="description" content="League One Volleyball — the first pro pathway built for American volleyball. Standings, Icons First Team, the founding story, and the pathway from youth club to LOVB Pro.">
<meta name="theme-color" content="#0A0908">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://api.fontshare.com" crossorigin>
<link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Marcellus&family=JetBrains+Mono:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

<style>
:root {
  --bg: #0A0908; --bg-1: #110F0D; --bg-2: #1A1715;
  --glass: rgba(255, 252, 245, 0.04);
  --glass-2: rgba(255, 252, 245, 0.08);
  --glass-edge: rgba(255, 252, 245, 0.14);
  --glass-edge-2: rgba(255, 252, 245, 0.22);
  --text: #F5F1E8;
  --text-2: rgba(245, 241, 232, 0.72);
  --text-3: rgba(245, 241, 232, 0.50);
  --text-4: rgba(245, 241, 232, 0.30);
  --accent: #FF5C3A;
  --accent-glow: rgba(255, 92, 58, 0.55);
  --gold: #F5B800;
  --gold-glow: rgba(245, 184, 0, 0.45);
  --moss: #6BAA5A;
  --r-1: 8px; --r-2: 12px; --r-3: 18px; --r-4: 24px; --r-pill: 9999px;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --section-py: 96px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; -webkit-font-smoothing: antialiased; background: #0A0908; color-scheme: dark; }
body {
  background: var(--bg); color: var(--text);
  font-family: "General Sans", -apple-system, sans-serif;
  font-size: 15px; line-height: 1.5;
  letter-spacing: -0.005em;
  min-height: 100vh; overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }

.masthead {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 18px 32px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px;
  background: linear-gradient(180deg, rgba(10,9,8,0.85), rgba(10,9,8,0.4));
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
}
.wordmark {
  font-family: "Anton"; font-size: 28px;
  letter-spacing: -0.005em; text-transform: uppercase;
  display: flex; align-items: center; gap: 4px;
}
.wordmark .dot {
  display: inline-block; width: 8px; height: 8px;
  background: var(--accent); border-radius: 50%;
  margin-left: 4px; margin-bottom: 4px;
  box-shadow: 0 0 14px var(--accent-glow);
}
.nav {
  display: flex; align-items: center; gap: 4px;
  font-family: "JetBrains Mono"; font-size: 11px;
  font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
}
.nav a {
  padding: 8px 14px; border-radius: var(--r-pill);
  color: var(--text-3);
  transition: all 0.2s var(--ease-out);
}
.nav a:hover { color: var(--text); background: var(--glass); }
.nav a.active { color: var(--text); background: var(--glass-2); }

/* ── Hero ──────────────────────────────────────────────── */
.lovb-hero {
  padding: 160px 32px 80px;
  text-align: center;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(245, 184, 0, 0.08), transparent 70%),
    linear-gradient(180deg, var(--bg) 0%, var(--bg-1) 100%);
  position: relative;
}
/* v0.30.5.136: LOVB HERO TEAM STRIP + LA28 COUNTDOWN */
.lovb-hero-teamstrip {
  display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
  margin: 24px 0 16px 0;
}
.lovb-hero-team {
  padding: 5px 14px;
  font-family: "JetBrains Mono", monospace;
  font-size: 10.5px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  font-weight: 600;
  color: var(--lovb-tc);
  background: color-mix(in srgb, var(--lovb-tc) 10%, transparent);
  border: 1px solid color-mix(in srgb, var(--lovb-tc) 45%, transparent);
  border-radius: 999px;
}
.lovb-hero-la28 {
  display: inline-flex; align-items: baseline; gap: 8px;
  margin-top: 8px;
  padding: 10px 18px;
  background: rgba(255,92,58,0.06);
  border: 1px solid rgba(255,92,58,0.25);
  border-radius: 999px;
}
.lovb-hero-la28-num {
  font-family: "Anton", sans-serif;
  font-size: 22px;
  color: var(--accent);
}
.lovb-hero-la28-lbl {
  font-family: "JetBrains Mono", monospace;
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-3);
}
.lovb-hero-eyebrow {
  font-family: "JetBrains Mono"; font-size: 11px;
  letter-spacing: 0.18em; color: var(--gold);
  text-transform: uppercase; margin-bottom: 28px;
}
.lovb-hero-h {
  font-family: "Anton", sans-serif;
  font-size: clamp(52px, 7vw, 104px);
  font-weight: 400; line-height: 0.92;
  letter-spacing: -0.015em;
  color: var(--text);
  margin: 0 auto 28px;
  max-width: 1100px;
}
.lovb-hero-h .serif {
  font-family: "Marcellus", serif;
  font-style: italic; font-weight: 400;
  color: var(--gold);
}
.lovb-hero-sub {
  font-family: "General Sans";
  font-size: 19px; line-height: 1.5;
  color: var(--text-2);
  max-width: 740px;
  margin: 0 auto;
}

/* ── Section wrappers ──────────────────────────────────── */
.lovb-section {
  padding: var(--section-py) 32px;
  max-width: 1200px;
  margin: 0 auto;
}
.lovb-section-eyebrow {
  font-family: "JetBrains Mono"; font-size: 11px;
  letter-spacing: 0.18em; color: var(--gold);
  text-transform: uppercase; margin-bottom: 18px;
  text-align: center;
}
.lovb-section-h {
  font-family: "Anton", sans-serif;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 400; line-height: 0.96;
  letter-spacing: -0.012em;
  text-align: center;
  margin: 0 auto 18px;
  max-width: 900px;
}
.lovb-section-h .serif {
  font-family: "Marcellus", serif;
  font-style: italic; color: var(--gold);
}
.lovb-section-sub {
  font-family: "General Sans";
  font-size: 16px; color: var(--text-2);
  text-align: center;
  max-width: 660px; margin: 0 auto 56px;
}

/* ── Standings (canonical league state) ─────────────────── */
.lovb-standings {
  background: var(--glass);
  border: 1px solid var(--glass-edge);
  border-radius: var(--r-3);
  overflow: hidden;
}
.lovb-standings-header {
  padding: 24px 28px;
  border-bottom: 1px solid var(--glass-edge);
  display: flex; justify-content: space-between; align-items: baseline;
  flex-wrap: wrap; gap: 12px;
}
.lovb-standings-h {
  font-family: "Anton", sans-serif;
  font-size: 22px; letter-spacing: 0.02em;
  text-transform: uppercase;
}
.lovb-standings-meta {
  font-family: "JetBrains Mono"; font-size: 11px;
  color: var(--text-3); letter-spacing: 0.08em;
  text-transform: uppercase;
}
.lovb-standing-row {
  display: grid;
  grid-template-columns: 60px 1fr 2fr;
  gap: 16px;
  padding: 18px 28px;
  border-bottom: 1px solid var(--glass-edge);
  align-items: center;
}
.lovb-standing-row:last-child { border-bottom: none; }
.lovb-standing-row.champion { background: rgba(245, 184, 0, 0.06); }
.lovb-standing-row.runner   { background: rgba(245, 184, 0, 0.03); }
.lovb-standing-rank {
  font-family: "Anton", sans-serif;
  font-size: 36px; line-height: 1;
  color: var(--text-3);
}
.lovb-standing-row.champion .lovb-standing-rank { color: var(--gold); }
.lovb-standing-team {
  font-family: "General Sans";
  font-size: 17px; line-height: 1.3;
}
.lovb-standing-team strong { font-weight: 600; color: var(--text); }
.lovb-standing-tag {
  display: inline-block;
  margin-left: 10px;
  font-family: "JetBrains Mono"; font-size: 10px;
  font-weight: 600; letter-spacing: 0.12em;
  padding: 3px 10px; border-radius: var(--r-pill);
  background: var(--glass); color: var(--text-3);
  text-transform: uppercase;
}
.lovb-standing-tag.champ { background: rgba(245, 184, 0, 0.16); color: var(--gold); }
.lovb-standing-tag.runner { color: var(--text-2); }
.lovb-standing-tag.semi { background: var(--glass-2); color: var(--text-2); }
.lovb-standing-detail {
  font-family: "General Sans";
  font-size: 14px;
  color: var(--text-3);
}
.lovb-standings-footer {
  padding: 20px 28px;
  text-align: center;
  font-family: "JetBrains Mono"; font-size: 11px;
  color: var(--text-3);
  letter-spacing: 0.05em;
}

/* ── Icons First Team buttons ──────────────────────────── */
.lovb-icons-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 12px;
  max-width: 1100px;
  margin: 0 auto;
}
.lovb-icon-btn {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18px 22px;
  background: var(--glass);
  border: 1px solid var(--glass-edge);
  border-radius: var(--r-2);
  font-family: "General Sans";
  font-size: 16px;
  color: var(--text);
  transition: all 0.2s var(--ease-out);
  cursor: pointer;
}
.lovb-icon-btn:hover {
  border-color: var(--gold);
  background: var(--glass-2);
  transform: translateY(-1px);
}
.lovb-icon-btn .pos {
  font-family: "JetBrains Mono"; font-size: 11px;
  font-weight: 600; letter-spacing: 0.12em;
  color: var(--gold);
  padding: 4px 8px;
  background: rgba(245, 184, 0, 0.10);
  border-radius: var(--r-pill);
}

/* ── Top-5 marquee lists (revived from the trimmed hub) ─── */
.lovb-top5-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 18px;
  max-width: 1200px;
  margin: 0 auto;
}
.lovb-top5 {
  padding: 26px 26px 22px;
  background: var(--glass);
  border: 1px solid var(--glass-edge);
  border-radius: var(--r-3);
}
.lovb-top5-h {
  font-family: "Anton", sans-serif;
  font-size: 18px; letter-spacing: 0.02em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 18px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--glass-edge);
}
.lovb-top5-list {
  list-style: none; padding: 0; margin: 0;
}
.lovb-top5-list li {
  padding: 12px 0;
  border-bottom: 1px solid var(--glass-edge);
  display: flex; flex-direction: column; gap: 4px;
}
.lovb-top5-list li:last-child { border-bottom: none; }
.lovb-top5-list li a {
  font-family: "General Sans";
  font-size: 15px;
  font-weight: 600;
  color: var(--text);
  transition: color 0.2s var(--ease-out);
}
.lovb-top5-list li a:hover { color: var(--gold); }
.lovb-top5-list li span {
  font-family: "General Sans";
  font-size: 12.5px;
  color: var(--text-3);
}

/* ── Pathway diagram ──────────────────────────────────── */
.lovb-pathway {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 14px;
  max-width: 1100px;
  margin: 0 auto;
}
.lovb-pathway-step {
  padding: 32px 26px;
  background: var(--glass);
  border: 1px solid var(--glass-edge);
  border-radius: var(--r-3);
  text-align: center;
}
.lovb-pathway-step-num {
  font-family: "Anton";
  font-size: 64px; line-height: 0.9;
  color: var(--gold);
  margin-bottom: 16px;
}
.lovb-pathway-step-h {
  font-family: "Anton";
  font-size: 22px; letter-spacing: 0.02em;
  text-transform: uppercase;
  margin-bottom: 10px;
}
.lovb-pathway-step-detail {
  font-family: "General Sans";
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.5;
}
.lovb-pathway-step strong { color: var(--text); font-weight: 600; }

/* ── Founding story ──────────────────────────────────── */
.lovb-founding {
  max-width: 880px;
  margin: 0 auto;
  padding: 48px 40px;
  background: var(--glass);
  border: 1px solid var(--glass-edge);
  border-radius: var(--r-3);
  text-align: center;
}
.lovb-founding-eyebrow {
  font-family: "JetBrains Mono"; font-size: 11px;
  letter-spacing: 0.18em; color: var(--gold);
  text-transform: uppercase; margin-bottom: 22px;
}
.lovb-founding-quote {
  font-family: "Marcellus", serif;
  font-style: italic;
  font-size: clamp(22px, 2.4vw, 30px);
  line-height: 1.4;
  color: var(--text);
  margin-bottom: 24px;
}
.lovb-founding-attr {
  font-family: "General Sans";
  font-size: 14px;
  color: var(--text-3);
  letter-spacing: 0.02em;
}
.lovb-founding-attr strong { color: var(--text-2); font-weight: 600; }

/* ── CTA back to product ──────────────────────────────── */
.lovb-cta {
  text-align: center;
  padding: 80px 32px 120px;
  background: linear-gradient(180deg, var(--bg-1) 0%, var(--bg) 100%);
}
.lovb-cta-h {
  font-family: "Anton";
  font-size: clamp(36px, 5vw, 56px);
  letter-spacing: -0.012em;
  margin-bottom: 14px;
}
.lovb-cta-sub {
  font-family: "General Sans";
  font-size: 16px; color: var(--text-2);
  margin-bottom: 32px;
}
.lovb-cta-btn {
  display: inline-block;
  padding: 16px 32px;
  background: var(--gold);
  color: var(--bg);
  border-radius: var(--r-pill);
  font-family: "JetBrains Mono"; font-size: 13px;
  font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase;
  transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out);
}
.lovb-cta-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px var(--gold-glow);
}

/* ── Footer ──────────────────────────────────────────── */
.lovb-footer {
  padding: 56px 32px 40px;
  border-top: 1px solid var(--glass-edge);
  text-align: center;
  background: var(--bg);
}
.lovb-footer-colophon {
  font-family: "JetBrains Mono"; font-size: 11px;
  color: var(--text-3);
  letter-spacing: 0.08em;
}

@media (max-width: 720px) {
  .nav a { padding: 6px 10px; font-size: 10px; }
  .lovb-hero { padding: 130px 20px 60px; }
  .lovb-section { padding: 64px 20px; }
  .lovb-standing-row { grid-template-columns: 44px 1fr; gap: 12px; padding: 14px 18px; }
  .lovb-standing-detail { grid-column: 1 / -1; padding-left: 56px; }
  .lovb-founding { padding: 32px 24px; }
}
</style>
</head>
<body>

<header class="masthead">
  <a href="/" class="wordmark">FIELDCHECK<span class="dot"></span></a>
  <!-- v0.30.5.2218 — CANONICAL NAV (V006). Source of truth, same on every page. -->
<header class="masthead fc-canonical-masthead">
  <a href="/" class="wordmark fc-canonical-wordmark">FieldCheck<span class="dot"></span></a>
  <nav class="nav fc-canonical-nav">
    <a href="/#buckets" class="nav-primary">Player</a>
    <a href="/#buckets" class="nav-primary">Program</a>
    <a href="/pathway" class="nav-primary" style="color:var(--moss, #95d5b2);font-weight:600">Pathway</a>
    <a href="/lovb" class="nav-primary" style="color:var(--gold, #ffc94a);font-weight:600">LOVB</a>
    <div class="nav-more-wrap" id="fc-nav-more-wrap">
      <button class="nav-primary nav-more-trigger" type="button" id="fc-nav-more-btn" aria-expanded="false" onclick="fcToggleNavMore(event)">More <span class="nav-more-chev">▾</span></button>
      <div class="nav-more-menu" id="fc-nav-more-menu" role="menu" aria-hidden="true">
        <div class="nav-more-group">
          <div class="nav-more-group-label">Tools</div>
          <a href="/voices" role="menuitem">Voices</a>
          <a href="/position-fit" role="menuitem">Position-Fit</a>
          <a href="/add-me" role="menuitem">Add Me</a>
          <a href="/coach" role="menuitem">Coach</a>
        </div>
        <div class="nav-more-group">
          <div class="nav-more-group-label">Newsroom</div>
          <a href="/wire" role="menuitem">The Wire</a>
        </div>
        <div class="nav-more-group">
          <div class="nav-more-group-label">Trust</div>
          <a href="/accuracy" role="menuitem">Track Record</a>
          <a href="/moat" role="menuitem">Moat</a>
        </div>
        <div class="nav-more-group">
          <div class="nav-more-group-label">For You · Personalized Path</div>
          <a href="/for-players" role="menuitem">For Players</a>
          <a href="/for-coaches" role="menuitem">For Coaches</a>
          <a href="/for-parents" role="menuitem">For Parents</a>
          <a href="/for-scouts" role="menuitem">For Scouts</a>
        </div>
        <div class="nav-more-group">
          <div class="nav-more-group-label">Company</div>
          <a href="/about" role="menuitem">About</a>
          <a href="/portal" role="menuitem">Portal</a>
        </div>
      </div>
    </div>
  </nav>
</header>

<style>
  /* v0.30.5.2218 — Canonical nav styling (self-contained, no host-CSS dependencies) */
  .fc-canonical-masthead {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 14px 24px; display: flex; align-items: center; justify-content: space-between;
    gap: 16px;
    background: linear-gradient(180deg, rgba(10,9,8,0.92), rgba(10,9,8,0.55));
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    font-family: 'General Sans', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  }
  .fc-canonical-wordmark {
    font-family: 'Anton', 'Bebas Neue', sans-serif;
    font-size: 22px; letter-spacing: -0.005em; text-transform: uppercase;
    color: #F5F1E8; text-decoration: none;
    display: flex; align-items: center; gap: 4px;
  }
  .fc-canonical-wordmark .dot {
    display: inline-block; width: 7px; height: 7px;
    background: #FF5C3A; border-radius: 50%;
    margin-left: 3px; margin-bottom: 2px;
    box-shadow: 0 0 12px rgba(255, 92, 58, 0.55);
  }
  .fc-canonical-nav { display: flex; align-items: center; gap: 4px; }
  .fc-canonical-nav .nav-primary {
    font-size: 14px; letter-spacing: 0.01em; padding: 8px 14px; margin: 0 3px;
    color: #F5F1E8; text-decoration: none;
    transition: color 0.18s; display: inline-block;
    background: transparent; border: 0; cursor: pointer;
    font-family: inherit;
  }
  .fc-canonical-nav .nav-primary:hover { color: #ffc94a; }
  .fc-canonical-nav .nav-more-wrap { position: relative; display: inline-block; }
  .fc-canonical-nav .nav-more-chev { display: inline-block; transition: transform 0.2s; font-size: 10px; margin-left: 2px; }
  .fc-canonical-nav .nav-more-wrap.open .nav-more-chev { transform: rotate(180deg); }
  .fc-canonical-nav .nav-more-menu {
    position: absolute; top: calc(100% + 6px); right: 0; min-width: 260px;
    background: rgba(20,17,12,0.96); backdrop-filter: blur(20px);
    border: 1px solid rgba(255,201,74,0.18); border-radius: 12px;
    padding: 14px 10px; box-shadow: 0 12px 40px rgba(0,0,0,0.55);
    opacity: 0; visibility: hidden; transform: translateY(-6px);
    transition: all 0.22s cubic-bezier(0.16, 1, 0.3, 1); z-index: 1000;
  }
  .fc-canonical-nav .nav-more-wrap.open .nav-more-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .fc-canonical-nav .nav-more-group { padding: 6px 4px; }
  .fc-canonical-nav .nav-more-group + .nav-more-group { border-top: 1px solid rgba(255,255,255,0.07); margin-top: 4px; padding-top: 12px; }
  .fc-canonical-nav .nav-more-group-label { font-family: 'JetBrains Mono', monospace; font-size: 9.5px; letter-spacing: 1.5px; color: rgba(255,201,74,0.65); font-weight: 700; padding: 0 8px 6px; text-transform: uppercase; }
  .fc-canonical-nav .nav-more-menu a { display: block; padding: 7px 10px; color: #d4c8ad; font-size: 13px; text-decoration: none; border-radius: 6px; transition: all 0.15s; font-family: inherit; }
  .fc-canonical-nav .nav-more-menu a:hover { background: rgba(255,201,74,0.08); color: #F5F1E8; }
  @media (max-width: 720px) {
    .fc-canonical-nav .nav-primary { font-size: 13px; padding: 6px 8px; margin: 0; }
    .fc-canonical-nav .nav-more-wrap { display: none; }
    .fc-canonical-wordmark { font-size: 18px; }
  }
  /* Spacer so page content doesn't get hidden under the fixed nav */
  body.fc-has-canonical-nav { padding-top: 64px; }
</style>

<script>
  function fcToggleNavMore(e) {
    if (e) e.stopPropagation();
    var wrap = document.getElementById('fc-nav-more-wrap');
    var btn  = document.getElementById('fc-nav-more-btn');
    var menu = document.getElementById('fc-nav-more-menu');
    if (!wrap || !btn || !menu) return;
    var open = wrap.classList.toggle('open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    menu.setAttribute('aria-hidden', open ? 'false' : 'true');
  }
  document.addEventListener('click', function(e) {
    var wrap = document.getElementById('fc-nav-more-wrap');
    if (wrap && wrap.classList.contains('open') && !wrap.contains(e.target)) {
      wrap.classList.remove('open');
      var btn = document.getElementById('fc-nav-more-btn');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    }
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      var wrap = document.getElementById('fc-nav-more-wrap');
      if (wrap && wrap.classList.contains('open')) {
        wrap.classList.remove('open');
        var btn = document.getElementById('fc-nav-more-btn');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      }
    }
  });
  // Add the body class once DOM is ready (so the padding-top spacer kicks in)
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function(){ document.body.classList.add('fc-has-canonical-nav'); });
  } else {
    document.body.classList.add('fc-has-canonical-nav');
  }
</script>
</header>

